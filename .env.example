# Bybit Trading System — Environment Configuration

# Required: API key (RSA sign-type 2 for mainnet)
BYBIT_API_KEY=your_mainnet_api_key_here

# Required: Path to RSA private key file (PEM format)
BYBIT_PRIVATE_KEY_PATH=./bybit_private.pem

# Optional: Demo/testnet keys (HMAC sign-type 1)
BYBIT_DEMO_API_KEY=your_demo_api_key_here
BYBIT_DEMO_API_SECRET=your_demo_api_secret_here

# Environment: mainnet or testnet
BYBIT_ENV=mainnet

# Optional: demo API URL (defaults to api-testnet.bybit.com if BYBIT_ENV=testnet)
# BYBIT_DEMO_API_URL=https://api-testnet.bybit.com
